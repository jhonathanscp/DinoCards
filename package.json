{
  "name": "flashcardapp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite -c vite.electron.config.js",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env NODE_ENV=development BROWSER=none npm run dev:electron\" \"wait-on http-get://127.0.0.1:5173 && electron .\"",
    "build:electron": "vite build -c vite.electron.config.js",
    "electron:build": "npm run build:electron && electron-builder"
  },
  "build": {
    "appId": "com.flashcardapp.desktop",
    "productName": "FlashCardApp Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron-main.cjs"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "axios": "^1.13.6",
    "localforage": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "laravel-vite-plugin": "^1.2.0",
    "postcss": "^8.4.48",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.4"
  }
}
